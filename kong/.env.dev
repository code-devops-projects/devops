# ============================================================================
# KONG GATEWAY - CONFIGURACIÓN DESARROLLO
# ============================================================================
# Archivo de variables de entorno para entorno de desarrollo
# Copiar este archivo y ajustar valores según necesidad

# ----------------------------------------------------------------------------
# CONFIGURACIÓN DE KONG
# ----------------------------------------------------------------------------
KONG_DATABASE=off
KONG_DECLARATIVE_CONFIG=/usr/local/kong/declarative/kong.yml
KONG_LOG_LEVEL=info

# Puertos de escucha de Kong
KONG_PROXY_LISTEN=0.0.0.0:8000, 0.0.0.0:8443 ssl
KONG_ADMIN_LISTEN=0.0.0.0:8001

# ----------------------------------------------------------------------------
# PUERTOS HOST - FRONTENDS PORTAL (Puerto interno :80)
# ----------------------------------------------------------------------------
CUSTOMER_PORTAL_PORT=3001
SECURITY_PORTAL_PORT=3002
INVENTORY_PORTAL_PORT=4201
INVOICE_PORTAL_PORT=4202

# ----------------------------------------------------------------------------
# PUERTOS HOST - FRONTENDS APP
# ----------------------------------------------------------------------------
CUSTOMER_APP_PORT=8101
SECURITY_APP_PORT=8102
INVENTORY_APP_PORT=8082
INVOICE_APP_PORT=9101

# ----------------------------------------------------------------------------
# PUERTOS HOST - BACKEND APIs
# ----------------------------------------------------------------------------
CUSTOMER_API_PORT=5001
SECURITY_API_PORT=5002
INVENTORY_API_PORT=5003
INVOICE_API_PORT=9001

# ----------------------------------------------------------------------------
# PUERTOS KONG
# ----------------------------------------------------------------------------
KONG_HTTP_PORT=80          # Puerto para frontends (portal + app)
KONG_API_PORT=8090         # Puerto para backend APIs
KONG_ADMIN_PORT=8001       # Puerto para Kong Admin API

# ----------------------------------------------------------------------------
# RED DOCKER
# ----------------------------------------------------------------------------
DOCKER_NETWORK=gateway_net

# ----------------------------------------------------------------------------
# SERVICIO FALLBACK
# ----------------------------------------------------------------------------
FALLBACK_PORT=5999
FALLBACK_SERVICE_NAME=fallback

# ----------------------------------------------------------------------------
# BASE DE DATOS (Para cuando se use DB mode)
# ----------------------------------------------------------------------------
# KONG_DATABASE=postgres
# KONG_PG_HOST=kong-database
# KONG_PG_PORT=5432
# KONG_PG_USER=kong
# KONG_PG_PASSWORD=kong_password
# KONG_PG_DATABASE=kong

# ----------------------------------------------------------------------------
# CONFIGURACIÓN DE RATE LIMITING (Opcional)
# ----------------------------------------------------------------------------
# RATE_LIMIT_MINUTE=1000
# RATE_LIMIT_HOUR=10000

# ----------------------------------------------------------------------------
# CORS (Opcional)
# ----------------------------------------------------------------------------
# CORS_ORIGINS=http://localhost:3000,http://localhost:4200
# CORS_CREDENTIALS=true

# ----------------------------------------------------------------------------
# AUTENTICACIÓN (Opcional)
# ----------------------------------------------------------------------------
# JWT_SECRET=your-secret-key-here
# JWT_EXPIRATION=3600

# ----------------------------------------------------------------------------
# NOTAS
# ----------------------------------------------------------------------------
# - Usar log level 'info' en desarrollo para balance entre debug y performance
# - Los servicios reales deben estar en la misma red Docker (gateway_net)
# - Para producción, cambiar a modo database (postgres) y habilitar HTTPS
# - Considerar habilitar rate limiting y CORS según necesidad
