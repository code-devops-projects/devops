# ============================================================================
# KONG GATEWAY - CONFIGURACIÓN LOCAL
# ============================================================================
# Archivo de variables de entorno para desarrollo local
# Copiar este archivo y ajustar valores según necesidad

# ----------------------------------------------------------------------------
# CONFIGURACIÓN DE KONG
# ----------------------------------------------------------------------------
KONG_DATABASE=off
KONG_DECLARATIVE_CONFIG=/usr/local/kong/declarative/kong.yml
KONG_LOG_LEVEL=debug

# Puertos de escucha de Kong
KONG_PROXY_LISTEN=0.0.0.0:8000, 0.0.0.0:8443 ssl
KONG_ADMIN_LISTEN=0.0.0.0:8001

# ----------------------------------------------------------------------------
# PUERTOS HOST - FRONTENDS PORTAL (Puerto interno :80)
# ----------------------------------------------------------------------------
CUSTOMER_PORTAL_PORT=3001
SECURITY_PORTAL_PORT=3002
INVENTORY_PORTAL_PORT=4201
INVOICE_PORTAL_PORT=4202

# ----------------------------------------------------------------------------
# PUERTOS HOST - FRONTENDS APP
# ----------------------------------------------------------------------------
CUSTOMER_APP_PORT=8101
SECURITY_APP_PORT=8102
INVENTORY_APP_PORT=8082
INVOICE_APP_PORT=9101

# ----------------------------------------------------------------------------
# PUERTOS HOST - BACKEND APIs
# ----------------------------------------------------------------------------
CUSTOMER_API_PORT=5001
SECURITY_API_PORT=5002
INVENTORY_API_PORT=5003
INVOICE_API_PORT=9001

# ----------------------------------------------------------------------------
# PUERTOS KONG
# ----------------------------------------------------------------------------
KONG_HTTP_PORT=80          # Puerto para frontends (portal + app)
KONG_API_PORT=8090         # Puerto para backend APIs (cambiado por conflicto con Jenkins en 8080)
KONG_ADMIN_PORT=8001       # Puerto para Kong Admin API

# ----------------------------------------------------------------------------
# RED DOCKER
# ----------------------------------------------------------------------------
DOCKER_NETWORK=gateway_net

# ----------------------------------------------------------------------------
# SERVICIO FALLBACK
# ----------------------------------------------------------------------------
FALLBACK_PORT=5999
FALLBACK_SERVICE_NAME=fallback

# ----------------------------------------------------------------------------
# VARIABLES DE SERVICIOS MOCK (Solo para desarrollo)
# ----------------------------------------------------------------------------
# Estas variables se usan cuando los servicios reales no están disponibles
MOCK_RESPONSE_DELAY=0      # Delay en segundos (0 = sin delay)
MOCK_LOG_LEVEL=INFO

# ----------------------------------------------------------------------------
# NOTAS
# ----------------------------------------------------------------------------
# - Puerto 8080 ocupado por Jenkins, por eso APIs backend en 8090
# - Los servicios mock retornan HTTP 503 con mensaje controlado
# - Modo DB-less: Kong usa configuración declarativa
# - Strip path habilitado en todas las rutas
